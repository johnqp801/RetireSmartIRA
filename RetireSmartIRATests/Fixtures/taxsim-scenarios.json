      "state_enum": "RetireSmartIRA USState rawValue",
      "filing_status": "single | marriedFilingJointly",
      "mstat": "TAXSIM mstat (1=single, 2=joint)",
      "primary_age": "page",
      "spouse_age": "sage (0 if single)",
      "wages_primary": "pwages",
      "wages_spouse": "swages",
      "pensions": "TAXSIM 'pensions' field — lumps IRA distributions + pensions",
      "gssi": "gross SS benefits",
      "intrec": "taxable interest",
      "dividends": "ordinary dividends (TAXSIM treats as ordinary)",
      "stcg": "net short-term cap gains",
      "ltcg": "net long-term cap gains",
      "engine_setup": "DataManager wiring: which slider/IncomeSource to use to materialize this scenario"
    }
  },
